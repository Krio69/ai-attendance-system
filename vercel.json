{
  "version": 2,
  "builds": [
    {
      "src": "web/attendance_project/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web/attendance_project/wsgi.py"
    }
  ],
  "buildCommand": "cd web && python manage.py collectstatic --noinput"
}