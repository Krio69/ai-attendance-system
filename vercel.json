{
  "framework": null,
  "outputDirectory": ".",
  "installCommand": "pip install -r web/requirements.txt",
  "buildCommand": "cd web && python manage.py migrate && python manage.py collectstatic --noinput",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/web/attendance_project/wsgi.py"
    }
  ]
}